# ── Veritabanı ──────────────────────────────────────────────────────────────
# MongoDB Atlas bağlantı dizesi (zorunlu)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# ── PayTR Ödeme Sistemi ─────────────────────────────────────────────────────
# https://www.paytr.com/ adresinden edinin
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt
# Test modda 1, canlıda 0
PAYTR_TEST_MODE=1
# Yerel geliştirme için PayTR API'si çağrılmaz (sahte token üretilir)
PAYTR_MOCK=true

# ── Site Ayarları ────────────────────────────────────────────────────────────
# Vercel'de deploy ettikten sonra kendi domain'inizi girin
SITE_URL=https://your-domain.vercel.app

# ── Admin Paneli ─────────────────────────────────────────────────────────────
# Admin giriş şifresi (güçlü bir şifre seçin, hiçbir zaman paylaşmayın)
ADMIN_PASSWORD=guclu-sifreniz-buraya
# JWT imzalama anahtarı (rastgele, uzun bir string)
ADMIN_JWT_SECRET=cok-gizli-ve-uzun-bir-jwt-anahtari-buraya

# ── İş Ayarları ──────────────────────────────────────────────────────────────
# Minimum sipariş tutarı (TL)
MIN_ORDER_AMOUNT=500
# Ücretsiz kargo limiti (TL) — bu tutarın üzerindeki siparişlerde kargo ücretsiz
FREE_SHIPPING_LIMIT=1500
# Standart kargo ücreti (TL)
SHIPPING_FEE=150
# IBAN ödemesinde indirim oranı (%)
IBAN_DISCOUNT_PERCENT=2

# ── IBAN / Havale Bilgileri ────────────────────────────────────────────────
IBAN_NUMBER=TR00 0000 0000 0000 0000 0000 00
IBAN_BANK=Garanti BBVA
IBAN_ACCOUNT_NAME=Asmalı Ambalaj Tic. Ltd. Şti.
